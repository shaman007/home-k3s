{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "registryAliases": {
    "harbor.andreybondarenko.com/dockerhub": "index.docker.io",
    "harbor.andreybondarenko.com/google": "gcr.io",
    "harbor.andreybondarenko.com/github": "ghcr.io",
    "harbor.andreybondarenko.com/quay": "quay.io"
  },
  "gitAuthor": "Andrey Bondarenko <me@andreybondarenko.com>",
  "argocd": {
    "managerFilePatterns": ["/^argocd\\/application-.*\\.ya?ml$/"]
  },
  "kubernetes": {
    "managerFilePatterns": ["/\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["index.docker.io/mongo"],
      "allowedVersions": "/^7(\\.|$)/"
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update"]
    }
  ]
}
