{
  "spec": {
    "template": {
      "spec": {
        "containers": [
          {
            "name": "nvidia-device-plugin-ctr",
            "env": [
              {"name": "FAIL_ON_INIT_ERROR", "value": "false"},
              {"name": "CONFIG_FILE", "value": "/config/time-slicing.yaml"}
            ],
            "volumeMounts": [
              {"name": "device-plugin", "mountPath": "/var/lib/kubelet/device-plugins"},
              {"name": "nvidia-device-plugin-config", "mountPath": "/config", "readOnly": true}
            ]
          }
        ],
        "volumes": [
          {"name": "device-plugin", "hostPath": {"path": "/var/lib/kubelet/device-plugins"}},
          {"name": "nvidia-device-plugin-config", "configMap": {"name": "nvidia-device-plugin-config"}}
        ]
      }
    }
  }
}
